# Copy to .env and fill in your real values from Firebase console
# Firebase Console → Project Settings → Your Apps → Web App → SDK config

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=hireadev-ai.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=hireadev-ai
VITE_FIREBASE_STORAGE_BUCKET=hireadev-ai.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Backend Cloud Functions base URL
# Firebase Console → Functions → Dashboard → copy the create_job URL, strip the function name
VITE_API_BASE_URL=https://us-central1-hireadev-ai.cloudfunctions.net
